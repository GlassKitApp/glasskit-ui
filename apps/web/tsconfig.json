{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@registry/*": ["../../registry/*"],
      // The registry is vendored source (not yet a package), so its files live
      // outside this app and can't resolve `react` from their own location under
      // pnpm. Pin React's types to this app's copy until the registry becomes a
      // real package with its own peerDependencies (deferred past the kill-gate).
      "react": ["./node_modules/@types/react"],
      "react/jsx-runtime": ["./node_modules/@types/react/jsx-runtime"],
      // Same story for the SDK: registry files import @glasskit-ui/react but
      // can't resolve it from their own location under pnpm. Point at the
      // workspace source (mirrors the vitest alias).
      "@glasskit-ui/react": ["../../packages/glasses-ui/src/index.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "../../registry/**/*.ts",
    "../../registry/**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
